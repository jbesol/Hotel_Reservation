    {
      "name": "Reservas",
      "item": [
        {
          "name": "Crear reserva",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"huespedId\": 1,\n  \"habitacionId\": 1,\n  \"checkIn\": \"2026-07-01\",\n  \"checkOut\": \"2026-07-05\",\n  \"observaciones\": \"Solicita habitación en piso alto\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/reservas",
              "host": ["{{base_url}}"],
              "path": ["reservas"]
            },
            "description": "Valida disponibilidad de fechas (previene double booking) y calcula el total automáticamente.\n\nEstado inicial: PENDIENTE."
          },
          "response": []
        },
        {
          "name": "Crear reserva — double booking (prueba)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"huespedId\": 2,\n  \"habitacionId\": 1,\n  \"checkIn\": \"2026-07-03\",\n  \"checkOut\": \"2026-07-07\",\n  \"observaciones\": \"Este request debe fallar con 400\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/reservas",
              "host": ["{{base_url}}"],
              "path": ["reservas"]
            },
            "description": "Intenta reservar la misma habitación en fechas solapadas con la reserva anterior. Debe devolver 400 Bad Request con el mensaje de conflicto."
          },
          "response": []
        },
        {
          "name": "Listar todas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas",
              "host": ["{{base_url}}"],
              "path": ["reservas"]
            }
          },
          "response": []
        },
        {
          "name": "Obtener por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Reservas por huésped",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/huesped/1",
              "host": ["{{base_url}}"],
              "path": ["reservas", "huesped", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Cambiar estado → CONFIRMADA",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1/estado?nuevoEstado=CONFIRMADA",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1", "estado"],
              "query": [{ "key": "nuevoEstado", "value": "CONFIRMADA" }]
            },
            "description": "Estados válidos: PENDIENTE → CONFIRMADA → CHECKED_IN → CHECKED_OUT\nTransiciones inválidas devuelven 400."
          },
          "response": []
        },
        {
          "name": "Cambiar estado → CHECKED_IN",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1/estado?nuevoEstado=CHECKED_IN",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1", "estado"],
              "query": [{ "key": "nuevoEstado", "value": "CHECKED_IN" }]
            }
          },
          "response": []
        },
        {
          "name": "Cambiar estado → CHECKED_OUT",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1/estado?nuevoEstado=CHECKED_OUT",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1", "estado"],
              "query": [{ "key": "nuevoEstado", "value": "CHECKED_OUT" }]
            }
          },
          "response": []
        },
        {
          "name": "Cambiar estado → CANCELADA",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1/estado?nuevoEstado=CANCELADA",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1", "estado"],
              "query": [{ "key": "nuevoEstado", "value": "CANCELADA" }]
            }
          },
          "response": []
        },
        {
          "name": "Transición inválida (prueba)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reservas/1/estado?nuevoEstado=PENDIENTE",
              "host": ["{{base_url}}"],
              "path": ["reservas", "1", "estado"],
              "query": [{ "key": "nuevoEstado", "value": "PENDIENTE" }]
            },
            "description": "Intenta volver a PENDIENTE desde CHECKED_OUT. Debe devolver 400 Bad Request."
          },
          "response": []
        }
      ]
    }
