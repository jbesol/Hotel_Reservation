{
  "info": {
    "_postman_id": "6b0a829d-77bc-4ba8-a6c9-56891decbc78",
    "name": "Hotel Reservation API",
    "description": "API REST para gestión de reservas del Hotel Grand Meridian.\n\nBase URL: http://localhost:8081/api/v1\n\nFlujo básico:\n1. Crear habitación (POST /habitaciones)\n2. Crear huésped (POST /huespedes)\n3. Crear reserva con los IDs obtenidos (POST /reservas)\n4. Cambiar estado de la reserva (PATCH /reservas/{id}/estado)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Habitaciones",
      "item": [
        {
          "name": "Crear habitación",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numHabitacion\": \"101\",\n  \"tipo\": \"SIMPLE\",\n  \"precioPorNoche\": 89.00,\n  \"capacidad\": 1,\n  \"descripcion\": \"Habitación individual con vista al jardín, TV 4K y ducha de lluvia.\",\n  \"disponible\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/habitaciones",
              "host": ["{{base_url}}"],
              "path": ["habitaciones"]
            },
            "description": "Crea una nueva habitación. Tipos válidos: SIMPLE, DOBLE, SUITE, PRESIDENCIAL."
          },
          "response": []
        },
        {
          "name": "Listar todas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones",
              "host": ["{{base_url}}"],
              "path": ["habitaciones"]
            }
          },
          "response": []
        },
        {
          "name": "Obtener por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones/1",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Listar disponibles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones/disponibles",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "disponibles"]
            }
          },
          "response": []
        },
        {
          "name": "Filtrar por tipo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones/tipo/SUITE",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "tipo", "SUITE"]
            },
            "description": "Tipos válidos: SIMPLE, DOBLE, SUITE, PRESIDENCIAL."
          },
          "response": []
        },
        {
          "name": "Disponibles por fechas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones/disponibles/fechas?checkIn=2026-07-01&checkOut=2026-07-05",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "disponibles", "fechas"],
              "query": [
                { "key": "checkIn",  "value": "2026-07-01" },
                { "key": "checkOut", "value": "2026-07-05" }
              ]
            },
            "description": "Devuelve habitaciones sin reservas activas (CONFIRMADA o CHECKED_IN) en el rango de fechas indicado."
          },
          "response": []
        },
        {
          "name": "Actualizar habitación",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numHabitacion\": \"101\",\n  \"tipo\": \"SIMPLE\",\n  \"precioPorNoche\": 99.00,\n  \"capacidad\": 1,\n  \"descripcion\": \"Habitación individual renovada con vista al jardín.\",\n  \"disponible\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/habitaciones/1",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Eliminar habitación",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/habitaciones/1",
              "host": ["{{base_url}}"],
              "path": ["habitaciones", "1"]
            }
          },
          "response": []
        }
      ]
    },
